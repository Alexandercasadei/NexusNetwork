{
  "hosting": {
    "public": "./",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "cors.json",
      "serve.json",
      "bs-config.js",
      "start_website.bat",
      "LICENSE",
      ".firebaserc"
    ],
    "rewrites": [
      { "source": "/team", "destination": "/pages/team/index.html" },
      { "source": "/live", "destination": "/pages/live/index.html" },
      { "source": "/creators", "destination": "/pages/creators/index.html" },
      { "source": "/services", "destination": "/pages/services/index.html" },
      { "source": "/contacts", "destination": "/pages/contacts/index.html" }
    ]
  }
}
